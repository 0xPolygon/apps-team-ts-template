PORT=3000
NODE_ENV=development
PRETTY_LOGS=true
# SENTRY_DSN=https://key@sentry.io/project

# Chain + contract to index. Both RPC vars are required; without them the
# service fails env validation at boot. The event ABI is a code constant
# (src/config/events.ts) — only the address and scan window are configurable.
RPC_URL=https://polygon-rpc.com
RPC_CHAIN_ID=137
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Cold-start scan origin; ignored once a cursor is persisted.
START_BLOCK=0
# Blocks per getLogs call (backfill + live tail).
BATCH_SIZE=500
# Live-tail poll cadence (ms).
POLLING_INTERVAL_MS=1000

# Persistence (example-db). Collections are namespaced by NETWORK.
NETWORK=mainnet
# Set only when pointing at a Firestore emulator (the SDK auto-detects it).
# Leave unset in production — the SDK uses Application Default Credentials.
# FIRESTORE_EMULATOR_HOST=localhost:8080
# The real GCP project in production; a `demo-*` id for the credential-free
# emulator.
GOOGLE_CLOUD_PROJECT_ID=demo-example-indexer
