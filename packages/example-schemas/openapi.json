{
  "openapi": "3.0.0",
  "info": {
    "title": "Example REST API",
    "version": "0.1.0",
    "description": "Stubbed REST API demonstrating the schemas/service/client monorepo pattern."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Shared secret. Required on operations declaring ApiKeyAuth."
      }
    },
    "schemas": {
      "HealthCheckResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "HelloResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "BlockNumberResponse": {
        "type": "object",
        "properties": {
          "blockNumber": {
            "type": "string",
            "pattern": "^-?\\d+$",
            "description": "Block height — fits in int64."
          }
        },
        "required": [
          "blockNumber"
        ],
        "description": "Latest block number from the configured RPC endpoint"
      },
      "BlockMetadata": {
        "type": "object",
        "properties": {
          "number": {
            "type": "string",
            "pattern": "^-?\\d+$"
          },
          "hash": {
            "type": "string"
          },
          "parentHash": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "pattern": "^-?\\d+$"
          }
        },
        "required": [
          "number",
          "hash",
          "parentHash",
          "timestamp"
        ],
        "description": "Block header metadata for a specific height"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "message": {
            "type": "string"
          },
          "info": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            }
          }
        },
        "required": [
          "error",
          "message"
        ],
        "description": "Standard error response shape from `@polygonlabs/express`'s `createErrorHandler`. `info` is present when the underlying `HTTPError` carries structured info (e.g. validation failures, domain-specific context); absent for plain errors and most non-validation HTTPErrors."
      },
      "NotFound": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "error",
          "message"
        ]
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "text",
          "createdAt"
        ]
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "message": {
            "type": "string"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "array",
                  "items": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      }
                    ]
                  }
                },
                "message": {
                  "type": "string"
                }
              },
              "required": [
                "path",
                "message"
              ]
            }
          }
        },
        "required": [
          "error",
          "message"
        ]
      },
      "CreateMessageRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 280
          }
        },
        "required": [
          "text"
        ]
      },
      "MessageList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Message"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "items",
          "nextCursor"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health-check": {
      "get": {
        "operationId": "getHealthCheck",
        "summary": "Liveness check",
        "responses": {
          "200": {
            "description": "Service is alive",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/hello": {
      "get": {
        "operationId": "getHello",
        "summary": "Hello world",
        "responses": {
          "200": {
            "description": "Greeting response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelloResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/block-number": {
      "get": {
        "operationId": "getBlockNumber",
        "summary": "Current block number",
        "description": "Returns the latest block number from the configured RPC endpoint.",
        "responses": {
          "200": {
            "description": "Latest block number",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlockNumberResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/blocks/{blockNumber}": {
      "get": {
        "operationId": "getBlockMetadata",
        "summary": "Block metadata by height",
        "description": "Looks up a block by its height via RPC and returns header metadata.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "pattern": "^-?\\d+$"
            },
            "required": true,
            "name": "blockNumber",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Block metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlockMetadata"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid x-api-key header",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Block not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              }
            }
          }
        }
      }
    },
    "/api/messages": {
      "post": {
        "operationId": "createMessage",
        "summary": "Create a message",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listMessages",
        "summary": "List messages",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "cursor",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "required": false,
            "name": "since",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Page of messages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageList"
                }
              }
            }
          }
        }
      }
    },
    "/api/messages/{id}": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get a message by id",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Message",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              }
            }
          }
        }
      }
    }
  }
}
