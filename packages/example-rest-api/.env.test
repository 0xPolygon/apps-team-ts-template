# PublicNode's free Ethereum mainnet RPC — no API key required, safe to commit.
RPC_URL=https://ethereum-rpc.publicnode.com
RPC_CHAIN_ID=1
# Test-only placeholder — operations declaring `security: [{ ApiKeyAuth: [] }]`
# require this header. Tests read the effective value from the environment
# (tests/env.ts), so an externally-injected key (the docker-release test job)
# wins over this placeholder — vitest.globalSetup.ts preserves it.
MANAGEMENT_API_KEY=test-secret
PRETTY_LOGS=true

# Cache-aside example: Redis + Firestore. These are placeholders that satisfy
# env validation in the hermetic unit suite (which never connects — the widget
# service is built lazily and only the integration suite hits it). The
# integration globalSetup OVERRIDES REDIS_URL / FIRESTORE_EMULATOR_HOST with
# the discovered EPHEMERAL docker-compose ports; the CI service containers map
# these exact ports, so that override is a no-op there. The `demo-*` project id
# keeps the Firestore emulator credential-free — which is why no secret lives
# in this committed file (see local-test-infrastructure best-practices doc).
REDIS_URL=localhost:6379
REDIS_CLUSTER=false
FIRESTORE_EMULATOR_HOST=localhost:8080
GOOGLE_CLOUD_PROJECT_ID=demo-example-rest-api
