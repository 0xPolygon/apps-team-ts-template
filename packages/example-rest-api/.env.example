PORT=3000
NODE_ENV=development
PRETTY_LOGS=true
# Local-dev placeholder — production gets a real secret from External Secrets.
MANAGEMENT_API_KEY=local-dev-secret
# SENTRY_DSN=https://key@sentry.io/project

# Public RPC for the block-number / block-metadata endpoints. Both vars are
# required by `src/env.ts`; without them the gateway fails env validation at
# boot. Public mainnet endpoint is fine for local dev — production uses the
# internal eRPC proxy via External Secrets.
RPC_URL=https://ethereum-rpc.publicnode.com
RPC_CHAIN_ID=1
