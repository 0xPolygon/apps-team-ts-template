PORT=3000
NODE_ENV=development
PRETTY_LOGS=true
# Local-dev placeholder — production gets a real secret from External Secrets.
MANAGEMENT_API_KEY=local-dev-secret
# SENTRY_DSN=https://key@sentry.io/project

# Public RPC for the block-number / block-metadata endpoints. Both vars are
# required by `src/env.ts`; without them the gateway fails env validation at
# boot. Public mainnet endpoint is fine for local dev — production uses the
# internal eRPC proxy via External Secrets.
RPC_URL=https://ethereum-rpc.publicnode.com
RPC_CHAIN_ID=1

# Cache-aside example (GET /api/widgets/{id}): Redis cache + Firestore source
# of truth. `host:port`, not a redis:// URI. Locally, run the integration
# suite (`pnpm run test:integration`) which manages both via docker-compose —
# you don't need these for tests. For `pnpm dev` against your own infra:
REDIS_URL=localhost:6379
REDIS_CLUSTER=false
# Set only when pointing at a Firestore emulator (the SDK auto-detects it).
# Leave unset in production — the SDK uses Application Default Credentials.
# FIRESTORE_EMULATOR_HOST=localhost:8080
# The real GCP project in production; a `demo-*` id for the credential-free
# emulator.
GOOGLE_CLOUD_PROJECT_ID=demo-example-rest-api

# Indexed-event read path (GET /events). example-db namespaces its collections
# by network — this MUST match the value example-indexer writes with, or the
# API reads an empty collection.
NETWORK=local
