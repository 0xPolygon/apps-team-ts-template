{
  "name": "example-rest-api",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "node src/index.ts",
    "dev": "dotenvx run -- node --conditions @polygonlabs/source src/index.ts",
