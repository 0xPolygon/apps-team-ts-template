    "@sentry/node": "^10.0.0",
    "@t3-oss/env-core": "^0.13.10",
    "cors": "^2.8.5",
    "croner": "^9.0.0",
    "ethers": "^6.16.0",
    "express": "^5.0.0",
    "helmet": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.0.0",
    "@polygonlabs/example-client": "workspace:*",
