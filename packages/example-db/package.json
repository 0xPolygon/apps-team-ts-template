{
  "name": "@polygonlabs/example-db",
  "version": "0.2.0",
  "description": "Firestore-backed typed stores for the indexer→db→REST showcase: an EventStore of decoded on-chain events and a per-chain cursor store.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.3",
  "exports": {
    ".": {
      "@polygonlabs/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm run typecheck && tsc -b tsconfig.lib.json",
    "build:clean": "pnpm run typecheck && rm -rf dist out-tsc *.tsbuildinfo && tsc -b tsconfig.lib.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist out-tsc node_modules *.tsbuildinfo"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node-ts": "^23.0.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/apps-team-ts-template.git",
    "directory": "packages/example-db"
  }
}
