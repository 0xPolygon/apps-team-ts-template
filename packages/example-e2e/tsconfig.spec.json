{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/spec",
    "tsBuildInfoFile": "out-tsc/spec/tsconfig.spec.tsbuildinfo",
    "types": ["vitest/globals", "vitest/importMeta", "node", "vitest"],
    "rewriteRelativeImportExtensions": false,
    "allowImportingTsExtensions": true
  },
  "include": ["test/**/*.ts", "vitest.e2e.config.ts"],
  "references": [
    { "path": "./tsconfig.lib.json" },
    { "path": "../example-db/tsconfig.lib.json" },
    { "path": "../example-indexer/tsconfig.lib.json" }
  ]
}
