    "typecheck": "tsc -b",
    "clean": "rm -rf node_modules dist out-tsc *.tsbuildinfo"
  },
  "devDependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@polygonlabs/example-db": "workspace:*",
    "@polygonlabs/example-indexer": "workspace:*",
    "@polygonlabs/logger": "^3.0.0",
    "@tsconfig/node-ts": "^23.0.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/node": "^24.0.0",
    "pino-pretty": ">=13.0.0",
    "typescript": "^5.5.0",
    "viem": "^2.37.0",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/apps-team-ts-template.git",
    "directory": "packages/example-e2e"
  }
