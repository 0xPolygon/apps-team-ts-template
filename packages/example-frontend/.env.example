# Copy to .env and fill in values

# Sequence project access key — required (from sequence.build)
VITE_SEQUENCE_PROJECT_ACCESS_KEY=project-access-key-placeholder
# Sequence wallet URL — required
VITE_SEQUENCE_WALLET_URL=https://sequence.app
# Dapp origin — required (your deployed domain, or localhost for dev)
VITE_DAPP_ORIGIN=http://localhost:5173
# WalletConnect project ID — optional (enables WalletConnect connector)
VITE_WALLET_CONNECT_PROJECT_ID=
# API URL for the example-rest-api service — required
VITE_API_URL=http://localhost:3001
# Sentry DSN — optional, enables error tracking
VITE_SENTRY_DSN=https://sentry-dsn-placeholder.sentry.io
