{
  "name": "@polygonlabs/example-client",
  "version": "0.2.2",
  "description": "Type-safe REST client for the Example REST API",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "exports": {
    ".": {
      "@polygonlabs/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./factory": {
      "@polygonlabs/source": "./src/generated/client/index.ts",
      "types": "./dist/generated/client/index.d.ts",
      "import": "./dist/generated/client/index.js"
    },
    "./react": {
      "@polygonlabs/source": "./src/react.ts",
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "generate": "openapi-ts -f openapi-ts.config.ts",
    "build": "pnpm run generate && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "codegen-drift-check": "pnpm run generate && git diff --exit-code -- src/generated",
    "clean": "rm -rf dist node_modules src/generated *.tsbuildinfo"
  },
  "dependencies": {
    "@polygonlabs/example-schemas": "workspace:*"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.1",
    "@hey-api/openapi-ts": "^0.95.0",
    "@polygonlabs/zod-to-openapi-heyapi": "^1.1.0",
    "@tanstack/react-query": "^5.0.0",
    "@tsconfig/node-ts": "^23.0.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/node": "^24.0.0",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/apps-team-ts-template.git",
    "directory": "packages/example-client"
  }
}
