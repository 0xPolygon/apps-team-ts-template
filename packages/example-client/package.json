{
  "name": "@polygonlabs/example-client",
  "version": "0.1.0",
  "description": "Type-safe REST client for the Example REST API",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "exports": {
    ".": {
      "@polygonlabs/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "@polygonlabs/source": "./src/react.ts",
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "generate": "orval --config orval.config.ts && node scripts/fix-extensions.ts",
    "build": "pnpm run generate && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules *.tsbuildinfo"
  },
  "devDependencies": {
    "@polygonlabs/example-schemas": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "@tsconfig/node-ts": "^23.0.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/node": "^24.0.0",
    "orval": "^8.5.2",
    "react": "^19.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/apps-team-ts-template.git",
    "directory": "packages/example-client"
  }
}
