{
  "name": "apps-team-ts-template",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/apps-team-ts-template.git"
  },
  "scripts": {
    "prepare": "husky",
    "release": "changeset publish",
    "ci:publish": "changeset publish",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "concurrently --group --prefix-colors auto 'pnpm:lint:md' 'pnpm:lint:ts' 'pnpm:typecheck' 'prettier --check .'",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:ts": "eslint .",
    "format": "pnpm run format:md && pnpm run format:ts && prettier --write .",
    "format:md": "markdownlint-cli2 --fix \"**/*.md\"",
    "format:ts": "eslint . --fix"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@polygonlabs/apps-team-lint": "^1.0.0",
    "@tsconfig/node-ts": "^23.0.0",
    "@tsconfig/node24": "^24.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "husky": "^9.0.0",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.0.0"
  }
}
